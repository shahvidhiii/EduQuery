# ══════════════════════════════════════════════
# EduQuery — Configuration
# ══════════════════════════════════════════════

# ── Ollama Configuration ──
OLLAMA_HOST=http://localhost:11434
EMBEDDING_MODEL=bge-m3
LLM_MODEL=llama3.2

# ── API Server ──
API_PORT=8000
API_HOST=127.0.0.1

# ── ChromaDB Backend ──
# Set to "true" to use ChromaDB instead of embeddings.pkl
# Run `python migrate_to_chromadb.py` first to migrate your data
USE_CHROMADB=true
CHROMA_DB_DIR=data/chroma_db
CHROMA_COLLECTION=video_chunks

# ── Video Serving ──
# Path to your video files (for clickable timestamp links)
# Source pills will still show without videos, but won't open the player
VIDEO_DIR=data/videos
AUDIO_DIR=data/audios
JSON_DIR=data/jsons
EMBEDDINGS_FILE=data/embeddings.pkl
